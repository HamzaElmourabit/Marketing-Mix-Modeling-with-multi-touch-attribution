# ===== GOOGLE CLOUD CONFIGURATION =====
# Path to your GCP service account key JSON file
# Download from: https://console.cloud.google.com/apis/credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# GCP Project ID
GCP_PROJECT_ID=rh-etl-project-467521

# BigQuery Dataset and Table
BIGQUERY_DATASET_ID=MMM_dataset
BIGQUERY_TABLE_ID=mmm

# ===== DATA PATHS =====
# Raw data location
RAW_DATA_PATH=data/raw/compressed_data.csv

# Processed data location
PROCESSED_DATA_PATH=data/processed/

# ===== LOGGING =====
LOG_LEVEL=INFO

# ===== STREAMLIT CONFIGURATION =====
# Theme
STREAMLIT_CLIENT_THEME=dark

# Server
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# ===== LOOKER CONFIGURATION =====
# Looker API credentials (for embedding dashboards)
# Get these from: Looker Admin → Users → Service Accounts

# Looker API Host (e.g., https://company.looker.com)
LOOKER_API_HOST=https://looker.company.com

# Looker API Key (from Service Account)
LOOKER_API_KEY=your-looker-api-key

# Looker API Secret (from Service Account)
LOOKER_API_SECRET=your-looker-api-secret

# Looker embedded dashboard IDs (comma-separated)
LOOKER_DASHBOARD_IDS=mmm_overview,channel_performance,roi_analysis

# Optional user context for embedded dashboards
LOOKER_EMBED_USER_EMAIL=mmm-user@company.com
LOOKER_EMBED_USER_NAME=MMM User

# ===== PYMC3 CONFIGURATION =====
# For modeling phase (optional)
PYMC_CORES=4
PYMC_DRAWS=2000
PYMC_TUNE=1000

# ===== AUTHENTICATION (Optional) =====
# For Streamlit Cloud authentication
STREAMLIT_CREDENTIALS_PATH=/path/to/credentials.json
